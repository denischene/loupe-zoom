{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "4.18.0",
  "default_locale": "fr",
  "description": "__MSG_extDesc__",
  "author": "Chêne Denis",
  "homepage_url": "https://loupe-zoom.lovable.app",
  "permissions": ["activeTab", "storage", "tabs", "scripting", "declarativeNetRequest"],
  "host_permissions": ["<all_urls>", "file:///*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "48": "icon-48.png",
      "128": "icon-128.png"
    },
    "default_title": "Loupe Zoom (Ctrl+Maj+Z)",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "commands": {
    "toggle-loupe": {
      "suggested_key": {
        "default": "Ctrl+Shift+Z"
      },
      "description": "Activer/désactiver la loupe"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>", "file:///*"],
      "js": ["browser-polyfill.js", "content.js"],
      "css": ["loupe.css"],
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["loupe.css", "pdfjs/web/viewer.html", "pdfjs/web/*", "pdfjs/build/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
