{
  "manifest_version": 2,
  "name": "Loupe Zoom",
  "version": "3.1.0",
  "description": "Loupe de zoom sur le curseur ou le focus clavier",
  "permissions": ["activeTab", "<all_urls>", "storage"],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_icon": {
      "48": "icon.png",
      "128": "icon.png"
    },
    "default_title": "Loupe Zoom",
    "theme_icons": [
      {
        "light": "icon.png",
        "dark": "icon-light.png",
        "size": 48
      },
      {
        "light": "icon.png",
        "dark": "icon-light.png",
        "size": 128
      }
    ]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "commands": {
    "toggle-loupe": {
      "suggested_key": {
        "default": "Ctrl+L"
      },
      "description": "Activer/désactiver la loupe"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["loupe.css"]
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}