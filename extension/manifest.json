{
  "manifest_version": 2,
  "name": "__MSG_extName__",
  "version": "4.18.0",
  "default_locale": "fr",
  "description": "__MSG_extDesc__",
  "author": "Chêne Denis",
  "homepage_url": "https://loupe-zoom.lovable.app",
  "permissions": ["activeTab", "<all_urls>", "file:///*", "storage", "webRequest", "webRequestBlocking", "tabs"],
  "web_accessible_resources": ["pdfjs/web/viewer.html", "pdfjs/web/*", "pdfjs/build/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "loupe-zoom@lovable.app",
      "strict_min_version": "113.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "113.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_icon": {
      "48": "icon-48.png",
      "128": "icon-128.png"
    },
    "default_title": "Loupe Zoom (Ctrl+Maj+Z)",
    "default_popup": "popup.html",
    "theme_icons": [
      {
        "light": "icon-light-48.png",
        "dark": "icon-48.png",
        "size": 48
      },
      {
        "light": "icon-light-128.png",
        "dark": "icon-128.png",
        "size": 128
      }
    ]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "commands": {
    "toggle-loupe": {
      "suggested_key": {
        "default": "Ctrl+Shift+Z"
      },
      "description": "Activer/désactiver la loupe"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>", "file:///*"],
      "js": ["content.js"],
      "css": ["loupe.css"],
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "icons": {
    "48": "icon-both-48.png",
    "128": "icon-both-128.png"
  }
}
